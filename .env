# ============================================================
# ForestSphere Summer School Mapping Demo — environment config
# Copy this file to .env and adjust paths for your machine.
# ============================================================

# ---- Dataset -----------------------------------------------
# By default bags are read from the bags/ folder next to docker-compose.yml.
# Uncomment and set this only if your bags are stored somewhere else.
# SUMMER_SCHOOL_DATASET_DIR=/path/to/summer_school_dataset

# Bag file paths relative to SUMMER_SCHOOL_DATASET_DIR
SUMMER_SCHOOL_RAW_BAG_PATTERN=raw_notf/2026_03_25_15_24_28__event-near_points__0_ros1_chunk_*_notf.bag
SUMMER_SCHOOL_PRUNE_BAG=semantic_pcl/prune_colored_rgb_no_gates_480p.bag
SUMMER_SCHOOL_SKY_MASK_BAG=raw/sky_mask_event_near_points_480p.bag
SUMMER_SCHOOL_LOCALIZATION_BAG=localisation_tf_50hz.bag

# Replay speed (1.0 = real-time)
SUMMER_SCHOOL_BAG_RATE=1.0

# ---- Robot description -------------------------------------
SUMMER_SCHOOL_CURTMINI_URDF=/workspace/demo/config/urdf/curtmini/robot.urdf.xacro
SUMMER_SCHOOL_RUN_CURTMINI_URDF=true
SUMMER_SCHOOL_RUN_STATIC_TFS=false

# ---- PRUNE -------------------------------------------------
SUMMER_SCHOOL_PRUNE_SEMANTIC_TOPIC=/camera/color/image_raw
SUMMER_SCHOOL_PRUNE_SEMANTIC_INPUT_TYPE=rgb
SUMMER_SCHOOL_PRUNE_CAMERA_INFO_TXT=/workspace/demo/calibration/curt_mini_realsense_camera_info_480p.txt

# ---- Mapper ------------------------------------------------
SUMMER_SCHOOL_MAPPER_BACKEND=dummy

# ---- ROS / display -----------------------------------------
ROS_MASTER_URI=http://localhost:11311
ROS_IP=127.0.0.1
DISPLAY=:1
QT_X11_NO_MITSHM=1
DISABLE_ROS1_EOL_WARNINGS=1

# ---- Docker image (optional overrides) ---------------------
SUMMER_SCHOOL_DEMO_IMAGE=forestsphere-summer-school-demo:noetic
SUMMER_SCHOOL_DEMO_USER=demo
SUMMER_SCHOOL_DEMO_UID=1000
SUMMER_SCHOOL_DEMO_GID=1000
