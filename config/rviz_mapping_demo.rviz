Panels:
  - Class: rviz/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /UFOMap1/Information1
        - /UFOMap1/Voxel Rendering1
      Splitter Ratio: 0.5
    Tree Height: 373
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: Image
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
