        back_right_wheel:
          Value: true
        base_link:
          Value: true
        base_visual:
          Value: true
        camera_color_optical_frame:
          Value: true
        camera_link:
          Value: true
        cameras_tower_visual:
          Value: true
        chassis:
          Value: true
        front_left_wheel:
          Value: true
        front_right_wheel:
          Value: true
        gps:
          Value: true
        imu_link:
          Value: true
        mag:
