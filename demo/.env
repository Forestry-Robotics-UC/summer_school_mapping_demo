# Raw replay bag pattern under SUMMER_SCHOOL_DATASET_DIR/bags. Points at the
# TF-stripped copies so recorded /tf and /tf_static do not fight live TF.
SUMMER_SCHOOL_RAW_BAG_PATTERN=raw_notf/2026_03_25_15_24_28__event-near_points__0_ros1_chunk_*_notf.bag

# PRUNE-colored replay bag (mapping-only mode input).
SUMMER_SCHOOL_PRUNE_BAG=semantic_pcl/prune_colored_rgb_no_gates_480p.bag

# Sky-mask bag paired with the raw chunk replay for PRUNE/full-pipeline modes.
SUMMER_SCHOOL_SKY_MASK_BAG=raw/sky_mask_event_near_points_480p.bag

# Localization/TF replay bag. Lives in the dataset root (no subfolder).
SUMMER_SCHOOL_LOCALIZATION_BAG=localisation_tf_50hz.bag

# rosbag play replay speed for live presentation runs.
SUMMER_SCHOOL_BAG_RATE=1.0

# Host dataset directory copied/synced from KDrive. Set to the root that
# contains raw/, raw_notf/, semantic_pcl/, and the localization bag.
SUMMER_SCHOOL_DATASET_DIR=${HOME}/datasets/summer_school

# Standard ROS/X11 names injected straight into the container via env_file.
# ROS master used by all demo terminals.
ROS_MASTER_URI=http://localhost:11311
# ROS IP for host-networked ROS1 inside Docker.
ROS_IP=127.0.0.1
# X11 display forwarded into the container for RViz.
DISPLAY=:1
# Avoid MIT-SHM issues with Qt over forwarded X11.
QT_X11_NO_MITSHM=1
# Silence the ROS1 Noetic end-of-life warning banner (e.g. from RViz/roscpp).
DISABLE_ROS1_EOL_WARNINGS=1

# CurtMini URDF, local to this demo repo (self-contained). Used by robot_state_publisher.
SUMMER_SCHOOL_CURTMINI_URDF=/workspace/demo/config/urdf/curtmini/robot.urdf.xacro
SUMMER_SCHOOL_RUN_CURTMINI_URDF=true

# Supplemental static TF YAML. Disabled: URDF (robot_state_publisher) plus the
# localization bag's map->odom /tf cover the full tree, so no fallback file is needed.
SUMMER_SCHOOL_RUN_STATIC_TFS=false

# PRUNE input/output topics for the prepared forest bag.
SUMMER_SCHOOL_PRUNE_SEMANTIC_TOPIC=/camera/color/image_raw
SUMMER_SCHOOL_PRUNE_SEMANTIC_INPUT_TYPE=rgb

# Camera intrinsics: use the bundled 480p RealSense text calibration as the
# primary source so PRUNE does not block waiting on a live CameraInfo topic.
SUMMER_SCHOOL_PRUNE_CAMERA_INFO_TXT=/workspace/demo/calibration/curt_mini_realsense_camera_info_480p.txt
# CameraInfo topic kept only as a fallback if a live driver is used instead of a bag.
# SUMMER_SCHOOL_PRUNE_CAMERA_INFO_TOPIC=/camera/color/camera_info

SUMMER_SCHOOL_PRUNE_DEPTH_INPUT_TOPIC=/ouster/points
SUMMER_SCHOOL_PRUNE_OUTPUT_TOPIC=/colored_pcl_node/semantic_pointcloud
SUMMER_SCHOOL_PRUNE_TARGET_FRAME=base_link
SUMMER_SCHOOL_PRUNE_PROJECTION_INVALID_MASK_TOPIC=/semantic/mask
SUMMER_SCHOOL_PRUNE_PROJECTION_INVALID_MASK_VALUE=255
SUMMER_SCHOOL_PRUNE_PROJECTION_INVALID_MASK_DILATE_PX=1

# PRUNE projection gates used for the summer-school forest replay.
SUMMER_SCHOOL_PRUNE_USE_INVALID_MASK=true
SUMMER_SCHOOL_PRUNE_USE_DEPTH_EDGE_REJECTION=true
SUMMER_SCHOOL_PRUNE_USE_OCCLUSION_GATE=true
SUMMER_SCHOOL_PRUNE_PROJECTION_PATCH_SIZE=3
SUMMER_SCHOOL_PRUNE_PROJECTION_CONFIDENCE_MIN=0.0
SUMMER_SCHOOL_PRUNE_PROJECTION_REJECT_DEPTH_EDGES=true
SUMMER_SCHOOL_PRUNE_PROJECTION_OCCLUSION_EPSILON_M=0.20
SUMMER_SCHOOL_PRUNE_PROJECTION_OCCLUSION_RADIUS_PX=1

# Mapping backend. Use dummy for maximum reliability; switch to bonxai/octomap
# only when that backend is built in the image.
SUMMER_SCHOOL_MAPPER_BACKEND=dummy
SUMMER_SCHOOL_MAPPER_SITE=forest
SUMMER_SCHOOL_MAPPER_WORLD_FRAME=world

# Build workspace automatically when entering the container if devel/setup.bash is missing.
SUMMER_SCHOOL_AUTO_CATKIN_BUILD=false
