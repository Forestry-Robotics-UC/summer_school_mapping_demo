<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="curt_mini">

  <!-- Mesh path prefix -->
<xacro:property name="mesh_prefix" value="file:///workspace/demo/config/urdf/curtmini/" />
  <!-- path to package -->
  <xacro:arg name="use_sim_time" default="true" />
  <!-- <xacro:arg name="gazebo_controllers" default="config/ros2_control_simulation.yaml" /> -->
  <xacro:arg name="simulation" default="False" />
  <!-- Import ros2_control -->
  <!-- <xacro:include filename="ros2_control.xacro" /> -->

  <!-- Include properties -->
  <xacro:include filename="properties.xacro" />

  <!-- Include sensors -->
  <xacro:include filename="sensors.xacro" />

  <link name="base_link" />

  <!-- Visual-only frame: base_link rotated 180 deg about Z. The STL bodies are mounted
       facing base_link +X, but the sensors/LiDAR (ground truth) face base_link -X, so the
       robot model appeared 180 deg off the real-world motion. Parenting the visual meshes
       here flips just the appearance; sensor frames, cloud geometry, and localization are
       untouched. -->
  <link name="base_visual" />
  <joint name="base_link_to_base_visual" type="fixed">
    <parent link="base_link" />
    <child link="base_visual" />
    <origin xyz="0 0 0" rpy="0 0 ${pi}" />
  </joint>

  <!-- Chassis link at same position as base_link, as root is not allowed to have inertial
  information -->
  <link name="chassis">
    <inertial>
      <origin xyz="0.011876 0.003999 0.048645" rpy="0 0 0" />
      <mass value="9.0318" />
      <inertia ixx="0.04558" ixy="-2.4654E-05" ixz="0.0014869" iyy="0.059986" iyz="2.4934E-05"
        izz="0.09132" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_prefix}/meshes/base_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_prefix}/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="base_to_chassis" type="fixed">
    <parent link="base_visual" />
    <child link="chassis" />
  </joint>

  <link name="front_right_wheel">
    <inertial>
      <origin xyz="-2.8086E-05 0.013016 2.8089E-05" rpy="0 0 0" />
      <mass value="0.61321" />
      <inertia ixx="0.0031957" ixy="-6.9366E-08" ixz="-8.7949E-07" iyy="0.0057902" iyz="6.9371E-08"
        izz="0.0031957" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_prefix}/meshes/wheel4_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0.01 0" rpy="${PI / 2} 0 0" />
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}" />
      </geometry>
    </collision>
  </link>
  <joint name="front_right_motor" type="fixed">
    <origin xyz="0.25995 -0.258 -0.030204" rpy="0 0 0" />
    <parent link="base_visual" />
    <child link="front_right_wheel" />
  </joint>

  <link name="front_left_wheel">
    <inertial>
      <origin xyz="2.8086E-05 -0.013016 2.8089E-05" rpy="0 0 0" />
      <mass value="0.61321" />
      <inertia ixx="0.0031957" ixy="-6.9366E-08" ixz="8.7949E-07" iyy="0.0057902" iyz="-6.9371E-08"
        izz="0.0031957" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_prefix}/meshes/wheel1_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 -0.01 0" rpy="${PI / 2} 0 0" />
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}" />
      </geometry>
    </collision>
  </link>
  <joint name="front_left_motor" type="fixed">
    <origin xyz="0.25995 0.258 -0.030204" rpy="0 0 0" />
    <parent link="base_visual" />
    <child link="front_left_wheel" />
  </joint>

  <link name="back_right_wheel">
    <inertial>
      <origin xyz="-2.8086E-05 0.013016 2.8089E-05" rpy="0 0 0" />
      <mass value="0.61321" />
      <inertia ixx="0.0031957" ixy="-6.9366E-08" ixz="-8.7949E-07" iyy="0.0057902" iyz="6.9371E-08"
        izz="0.0031957" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_prefix}/meshes/wheel3_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0.01 0" rpy="${PI / 2} 0 0" />
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}" />
      </geometry>
    </collision>
  </link>
  <joint name="back_right_motor" type="fixed">
    <origin xyz="-0.26 -0.258 -0.022755" rpy="0 0 0" />
    <parent link="base_visual" />
    <child link="back_right_wheel" />
  </joint>

  <link name="back_left_wheel">
    <inertial>
      <origin xyz="2.8086E-05 -0.013016 2.8089E-05" rpy="0 0 0" />
      <mass value="0.61321" />
      <inertia ixx="0.0031957" ixy="-6.9366E-08" ixz="8.7949E-07" iyy="0.0057902" iyz="-6.9371E-08"
        izz="0.0031957" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_prefix}/meshes/wheel2_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 -0.01 0" rpy="${PI / 2} 0 0" />
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}" />
      </geometry>
    </collision>
  </link>
  <joint name="back_left_motor" type="fixed">
    <origin xyz="-0.26 0.258 -0.022755" rpy="0 0 0" />
    <parent link="base_visual" />
    <child link="back_left_wheel" />
  </joint>

  <!-- Import gazebo infos -->
  <xacro:if value="$(arg simulation)">
    <xacro:include filename="gazebo.xacro" />
  </xacro:if>

</robot>