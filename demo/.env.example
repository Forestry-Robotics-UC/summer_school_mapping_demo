# Raw replay bag pattern under SUMMER_SCHOOL_DATASET_DIR/bags/raw.
SUMMER_SCHOOL_RAW_BAG_PATTERN=raw/2026_03_25_15_24_28__event-near_points__0_ros1_chunk_*.bag

# PRUNE-colored replay bag under SUMMER_SCHOOL_DATASET_DIR/bags/semantic_pcl.
SUMMER_SCHOOL_PRUNE_BAG=semantic_pcl/prune_colored_event_near_points_480p.bag

# Sky-mask bag paired with the raw chunk replay for PRUNE/full-pipeline modes.
SUMMER_SCHOOL_SKY_MASK_BAG=raw/sky_mask_event_near_points_480p.bag

# Localization/TF replay bag used to provide the mapping frames during bag replay.
SUMMER_SCHOOL_LOCALIZATION_BAG=localization/localisation_tf_50hz.bag

# rosbag play replay speed for live presentation runs.
SUMMER_SCHOOL_BAG_RATE=0.3

# Host dataset directory copied/synced from KDrive. Set to one concrete *event_points folder; Compose does not expand globs.
SUMMER_SCHOOL_DATASET_DIR=${HOME}/datasets/summer_school

# ROS master used by all demo terminals.
SUMMER_SCHOOL_ROS_MASTER_URI=http://localhost:11311

# ROS IP for host-networked ROS1 inside Docker.
SUMMER_SCHOOL_ROS_IP=127.0.0.1

# Optional container user identity override for the maintainer image.
SUMMER_SCHOOL_DEMO_USER=demo
SUMMER_SCHOOL_DEMO_UID=1000
SUMMER_SCHOOL_DEMO_GID=1000

# X11 display forwarded into the container for RViz.
SUMMER_SCHOOL_DISPLAY=:0

# Optional local PRUNE source mount used to build/run prune_ros in this demo container.
PRUNE_SOURCE_DIR=../../PRUNE

# Optional local ENTFAC-Mapping source mount used for the semantic mapper.
MAPPING_SOURCE_DIR=../../ENTFAC-Mapping

# Optional UFOMapping source mount. Leave as demo/vendor/ufomap unless a real ufomap catkin source tree is available.
UFOMAP_SOURCE_DIR=./vendor/ufomap

# CurtMini calibrated URDF from ENTFAC-Mapping. Used by robot_state_publisher in run_demo.sh.
SUMMER_SCHOOL_CURTMINI_URDF=/workspace/catkin_ws/src/entfac_mapping/entfac_mapping_ros/urdf/curtmini/robot.urdf.xacro
SUMMER_SCHOOL_RUN_CURTMINI_URDF=true

# Supplemental static TF YAML. Keep true for map->odom or demo-only fallback TFs.
SUMMER_SCHOOL_RUN_STATIC_TFS=true

# PRUNE input/output topics for the prepared forest bag.
SUMMER_SCHOOL_PRUNE_SEMANTIC_TOPIC=/semantic/mask
SUMMER_SCHOOL_PRUNE_SEMANTIC_INPUT_TYPE=labels
SUMMER_SCHOOL_PRUNE_CAMERA_INFO_TXT=/workspace/demo/calibration/curt_mini_realsense_camera_info_480p.txt
SUMMER_SCHOOL_PRUNE_CAMERA_INFO_TOPIC=/camera/color/camera_info
SUMMER_SCHOOL_PRUNE_DEPTH_INPUT_TOPIC=/ouster/points
SUMMER_SCHOOL_PRUNE_OUTPUT_TOPIC=/colored_pcl_node/semantic_pointcloud
SUMMER_SCHOOL_PRUNE_TARGET_FRAME=base_link
SUMMER_SCHOOL_PRUNE_PROJECTION_INVALID_MASK_TOPIC=/semantic/mask
SUMMER_SCHOOL_PRUNE_PROJECTION_INVALID_MASK_VALUE=255
SUMMER_SCHOOL_PRUNE_PROJECTION_INVALID_MASK_DILATE_PX=1

# PRUNE projection gates used for the summer-school forest replay.
SUMMER_SCHOOL_PRUNE_USE_INVALID_MASK=true
SUMMER_SCHOOL_PRUNE_USE_DEPTH_EDGE_REJECTION=true
SUMMER_SCHOOL_PRUNE_USE_OCCLUSION_GATE=true
SUMMER_SCHOOL_PRUNE_PROJECTION_PATCH_SIZE=3
SUMMER_SCHOOL_PRUNE_PROJECTION_CONFIDENCE_MIN=0.0
SUMMER_SCHOOL_PRUNE_PROJECTION_REJECT_DEPTH_EDGES=true
SUMMER_SCHOOL_PRUNE_PROJECTION_OCCLUSION_EPSILON_M=0.20
SUMMER_SCHOOL_PRUNE_PROJECTION_OCCLUSION_RADIUS_PX=1

# Mapping backend. Use dummy for maximum reliability; switch to bonxai/octomap only when that backend is built in the image.
SUMMER_SCHOOL_MAPPER_BACKEND=dummy
SUMMER_SCHOOL_MAPPER_SITE=forest
SUMMER_SCHOOL_MAPPER_WORLD_FRAME=map

# Build workspace automatically when entering the container if devel/setup.bash is missing.
SUMMER_SCHOOL_AUTO_CATKIN_BUILD=false
